{
  "name": "@home-coffing/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "schema:create": "mikro-orm schema:create --run",
    "schema:update": "mikro-orm schema:update --run",
    "schema:drop": "mikro-orm schema:drop --run",
    "migrate:prod": "ts-node scripts/migrate-from-prod.ts"
  },
  "dependencies": {
    "@home-coffing/shared-types": "workspace:*",
    "@mikro-orm/cli": "^6",
    "@mikro-orm/core": "^6",
    "@mikro-orm/migrations": "^6",
    "@mikro-orm/mysql": "^6",
    "@mikro-orm/nestjs": "^6",
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11",
    "@nestjs/passport": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/schedule": "^5",
    "bcryptjs": "^3",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "dotenv": "^17",
    "passport": "^0.7",
    "passport-jwt": "^4",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "uuid": "^11"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/mikro-orm.config.ts"
    ]
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@types/bcryptjs": "^3",
    "@types/express": "^5",
    "@types/node": "^22",
    "@types/passport-jwt": "^4",
    "@types/uuid": "^10",
    "ts-node": "^10.9.2",
    "typescript": "^5.7"
  }
}
